{
  "name": "dropfleet-legionaires",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "pnpm --filter federation-legionaires-server dev",
    "dev:client": "pnpm --filter federation-legionaires-client dev",
    "build": "pnpm --filter @legionaires/shared build && pnpm --filter federation-legionaires-server build && pnpm --filter federation-legionaires-client build",
    "build:shared": "pnpm --filter @legionaires/shared build",
    "build:server": "pnpm --filter federation-legionaires-server build",
    "build:client": "pnpm --filter federation-legionaires-client build"
  }
}
